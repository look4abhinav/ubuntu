[credential "https://github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
[core]
	preloadindex = true
	fsmonitor = true
	untrackedcache = true
[gc]
	auto = 8000
[pack]
	threads = 0
	windowMemory = 1g
	packSizeLimit = 512m
[rebase]
	autoStash = true
[merge]
	autoStash = true
[push]
	default = current
	autoSetupRemote = true
[fetch]
	prune = true
	pruneTags = true
[branch]
	sort = -committerdate
[help]
	autoCorrect = prompt
[alias]
	st = status -s
	ci = commit
	co = checkout
	br = branch
	lg = log --oneline --graph
[user]
	name = Abhinav Srivastava
	email = look4abhinav@outlook.in
	signingkey = /home/abhinav/.ssh/id_ed25519.pub
[gpg]
	format = ssh
[commit]
	gpgSign = true
[init]
	defaultBranch = main
[diff]
	algorithm = histogram